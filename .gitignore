# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
.wrangler/
*.local

# Env files — only .env.example is committed
.env
.env.local
.env.*.local

# Firebase service account (do NOT commit)
serviceAccount.json
*-firebase-adminsdk-*.json

# Test results
test-results/
coverage/

# Batch-import workspace (large intermediates, never commit)
tmp/
scripts/run-batch.bat

# Source documents (exam DOCX archives etc.) — binary inputs, never commit
content-sources/

# Generated deliverables (dictionary docx/csv etc.) — outputs, never commit
deliverables/

# TuDien deliverables (generated outputs, do not commit; generator scripts live in tmp/dict)
TuDien_*.docx
TuDien_*.json
TuDien_*.csv

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Python bytecode
__pycache__/
*.pyc
