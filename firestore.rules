rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    // ─── Per-user documents: users / progress / pets ─────────────────────
    // Reads (get + list) are open to any signed-in user — this is what the
    // leaderboard + analytics dashboards both rely on; matches the previous
    // rules so existing student flows don't break. Writes are locked down:
    // only the owner can create/update their own doc; admin can update users
    // for moderation; nobody can delete.
    match /users/{uid} {
      allow read:   if isSignedIn();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    match /progress/{uid} {
      allow read:   if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    match /pets/{uid} {
      allow read:   if isSignedIn();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── Admin-managed content: exams / sgk ─────────────────────────────
    // Anyone signed in can read (students need to take exams / view units).
    // Only admins can write (upload/edit via /admin panel).
    match /exams/{grade}/tests/{examId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /sgk/{grade}/units/{unitId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── AI grading attempts: speaking / writing ─────────────────────────
    // Owner creates + reads their own; admin reads all for review.
    // Nobody updates/deletes — attempts are append-only history.
    match /speaking_attempts/{uid}/items/{attemptId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create:    if isOwner(uid);
      allow update, delete: if false;
    }
    match /writing_attempts/{uid}/items/{attemptId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create:    if isOwner(uid);
      allow update, delete: if false;
    }

    // ─── Deny everything else by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
