rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && request.auth.token.email in ["truongnq.vie@gmail.com", "buiyen.701@gmail.com"];
    }
    // Guest mode cấp identity ẩn danh cho MỌI khách vãng lai, nên
    // isSignedIn() một mình không còn là rào chắn. isPermanent() phân biệt
    // tài khoản thật (Google) với tài khoản ẩn danh.
    function isPermanent() {
      return isSignedIn() && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    // ─── Per-user documents: users / progress / pets ─────────────────────
    // Đọc chéo (leaderboard/analytics) chỉ dành cho tài khoản thật hoặc
    // admin — khách ẩn danh KHÔNG được liệt kê dữ liệu của người khác,
    // chỉ đọc/ghi doc của chính mình. Ghi: chỉ chính chủ tạo/sửa doc của
    // mình; admin được sửa users để kiểm duyệt; không ai được xoá.
    match /users/{uid} {
      allow read:   if isOwner(uid) || isPermanent() || isAdmin();
      allow create: if isOwner(uid);
      allow update: if isOwner(uid) || isAdmin();
      allow delete: if false;
    }

    match /progress/{uid} {
      allow read:   if isOwner(uid) || isPermanent() || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // Pet chỉ được chính chủ đọc trong app — không cần đọc chéo.
    match /pets/{uid} {
      allow read:   if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── Admin-managed content: exams / sgk ─────────────────────────────
    // Mọi user đã đăng nhập (kể cả khách ẩn danh) đọc được — nội dung học
    // là tính năng guest mode. Chỉ admin được ghi (upload/sửa qua /admin).
    match /exams/{grade}/tests/{examId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }
    match /sgk/{grade}/units/{unitId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Video lessons: cô giáo tạo bài từ URL YouTube; học sinh đọc để luyện thuộc.
    match /video_lessons/{lessonId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // Tiến độ học thuộc video theo từng học sinh.
    match /video_lesson_progress/{uid}/lessons/{lessonId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create, update: if isOwner(uid);
      allow delete: if false;
    }

    // ─── AI grading attempts: speaking / writing ─────────────────────────
    // Owner creates + reads their own; admin reads all for review.
    // Nobody updates/deletes — attempts are append-only history.
    match /speaking_attempts/{uid}/items/{attemptId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create:    if isOwner(uid);
      allow update, delete: if false;
    }
    match /writing_attempts/{uid}/items/{attemptId} {
      allow get, list: if isOwner(uid) || isAdmin();
      allow create:    if isOwner(uid);
      allow update, delete: if false;
    }

    // ─── Deny everything else by default ────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
